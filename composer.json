{
    "name": "takigawaakinori/phpunit-profiler",
    "description": "A PHPUnit extension that profiles and reports the slowest tests",
    "type": "phpunit-extension",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0 || ^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "TakigawaAkinori\\PhpunitProfiler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TakigawaAkinori\\PhpunitProfiler\\Tests\\": "tests/"
        }
    }
}
